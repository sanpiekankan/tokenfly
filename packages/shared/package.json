{
  "name": "@tokenfly/shared",
  "version": "1.1.0",
  "private": true,
  "description": "Shared utilities for the tokenfly workspace.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --tsconfig tsconfig.json",
    "test": "vitest run tests",
    "lint": "eslint src --ext .ts"
  }
}
