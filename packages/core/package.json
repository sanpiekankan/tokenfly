{
  "name": "@tokenfly/core",
  "version": "1.0.1",
  "description": "Core token estimation, cost calculation, and budget control for tokenfly.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --tsconfig tsconfig.json",
    "test": "vitest run packages/core",
    "lint": "eslint src tests --ext .ts"
  },
  "dependencies": {
    "@tokenfly/shared": "1.0.1"
  }
}
